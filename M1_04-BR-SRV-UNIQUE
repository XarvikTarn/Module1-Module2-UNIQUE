hostnamectl set-hostname BR-SRV.au-team.irpo && exec bash
sed -i 's|http://ftp.altlinux.org/pub/distributions/ALTLinux|http://10.45.33.250:3142/altlinux|g' /etc/apt/sources.list.d/alt.list
rm -rf /etc/net/ifaces/enp7s1
mkdir /etc/net/ifaces/enp7s1
echo "TYPE=eth" > /etc/net/ifaces/enp7s1/options
echo "172.16.10.2/[ВСТАВЬ_МАСКУ_СЮДА]" > /etc/net/ifaces/enp7s1/ipv4address
echo "default via 172.16.10.1" > /etc/net/ifaces/enp7s1/ipv4route
echo "nameserver 8.8.8.8" > /etc/net/ifaces/enp7s1/resolv.conf
systemctl restart network && sleep 3
apt-get update && apt-get install -y tzdata 
timedatectl set-timezone Asia/Vladivostok && date 
useradd -u 2026 -m -s /bin/bash sshuser
echo "sshuser:P@ssw0rd" | chpasswd
echo "sshuser ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/sshuser
echo "Authorized access only" > /etc/issue.net
cat <<EOF >> /etc/openssh/sshd_config

# Hardening Rules
Port 2026
PermitRootLogin no
MaxAuthTries 2
Banner /etc/issue.net
AllowUsers sshuser
EOF
echo "nameserver 172.16.100.2" > /etc/net/ifaces/enp7s1/resolv.conf
systemctl restart network
systemctl restart sshd
history -a
